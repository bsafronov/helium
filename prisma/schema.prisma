generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "mongodb"
    url      = env("DATABASE_URL")
}

// * <NextAuth> *
model Account {
    id String @id @default(auto()) @map("_id") @db.ObjectId

    type              String
    provider          String
    providerAccountId String
    refresh_token     String? // @db.Text
    access_token      String? // @db.Text
    expires_at        Int?
    token_type        String?
    scope             String?
    id_token          String? // @db.Text
    session_state     String?

    userId String @db.ObjectId
    user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@unique([provider, providerAccountId])
}

model Session {
    id           String   @id @default(auto()) @map("_id") @db.ObjectId
    sessionToken String   @unique
    expires      DateTime

    userId String @db.ObjectId
    user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
    id         String   @id @default(auto()) @map("_id") @db.ObjectId
    identifier String
    token      String   @unique
    expires    DateTime

    @@unique([identifier, token])
}

// * </NextAuth> *

model User {
    id            String    @id @default(auto()) @map("_id") @db.ObjectId
    username      String    @unique @default(uuid())
    name          String?
    email         String?   @unique
    emailVerified DateTime?
    image         String?

    accounts Account[]
    sessions Session[]

    groupIDs String[] @db.ObjectId
    groups   Group[]  @relation("groups", fields: [groupIDs], references: [id])

    groupAdminIDs String[] @db.ObjectId
    groupsAdmin   Group[]  @relation("groupsAdmin", fields: [groupAdminIDs], references: [id])

    createdGroups  Group[]
    createdTables  Table[]
    createdForms   Form[]
    uploadedImages Image[]

    subscribedTo Subscription[] @relation("subsBy")
    subscribedBy Subscription[] @relation("subsTo")

    chatIDs String[] @db.ObjectId
    chats   Chat[]   @relation("chatUsers", fields: [chatIDs], references: [id])

    chatsAdminIDs String[] @db.ObjectId
    chatsAdmin    Chat[]   @relation("chatAdmins", fields: [chatsAdminIDs], references: [id])

    messages Message[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

model Subscription {
    id String @id @default(auto()) @map("_id") @db.ObjectId

    subscribedToId String @db.ObjectId
    subscribedTo   User   @relation("subsTo", fields: [subscribedToId], references: [id])

    subscribedById String @db.ObjectId
    subscribedBy   User   @relation("subsBy", fields: [subscribedById], references: [id])
}

model Chat {
    id String @id @default(auto()) @map("_id") @db.ObjectId

    userIDs String[] @db.ObjectId
    users   User[]   @relation("chatUsers", fields: [userIDs], references: [id])

    adminIDs String[] @db.ObjectId
    admins   User[]   @relation("chatAdmins", fields: [adminIDs], references: [id])

    messages Message[]
}

model Message {
    id   String @id @default(auto()) @map("_id") @db.ObjectId
    body String

    createdById String @db.ObjectId
    createdBy   User   @relation(fields: [createdById], references: [id])

    chatId String @db.ObjectId
    chat   Chat   @relation(fields: [chatId], references: [id])

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

model Group {
    id          String  @id @default(auto()) @map("_id") @db.ObjectId
    title       String
    urlName     String  @unique @default(uuid())
    description String?
    avatar      String?
    isPublic    Boolean @default(false)

    userIDs String[] @db.ObjectId
    users   User[]   @relation("groups", fields: [userIDs], references: [id])

    adminIDs String[] @db.ObjectId
    admins   User[]   @relation("groupsAdmin", fields: [adminIDs], references: [id])

    tableIDs String[] @db.ObjectId
    tables   Table[]  @relation(fields: [tableIDs], references: [id])

    createdById String @db.ObjectId
    createdBy   User   @relation(fields: [createdById], references: [id])

    pages GroupPage[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

model GroupPage {
    id    String @id @default(auto()) @map("_id") @db.ObjectId
    title String

    groupId String @db.ObjectId
    group   Group  @relation(fields: [groupId], references: [id])
}

model Table {
    id       String  @id @default(auto()) @map("_id") @db.ObjectId
    isPublic Boolean @default(true)
    body     Json

    groupIDs String[] @db.ObjectId
    groups   Group[]  @relation(fields: [groupIDs], references: [id])

    createdById String @db.ObjectId
    createdBy   User   @relation(fields: [createdById], references: [id])

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

model Form {
    id       String  @id @default(auto()) @map("_id") @db.ObjectId
    isPublic Boolean @default(true)
    body     Json

    createdById String @db.ObjectId
    createdBy   User   @relation(fields: [createdById], references: [id])

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

model Image {
    id  String @id @default(auto()) @map("_id") @db.ObjectId
    url String

    createdById String @db.ObjectId
    createdBy   User   @relation(fields: [createdById], references: [id])
}
